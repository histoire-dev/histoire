{
  "name": "@histoire/vendors",
  "type": "module",
  "version": "1.0.0-beta.1",
  "description": "Bundled vendors for histoire",
  "author": {
    "name": "Guillaume Chau"
  },
  "license": "MIT",
  "repository": {
    "url": "https://github.com/Akryum/histoire.git",
    "type": "git",
    "directory": "packages/histoire-vendors"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    "./floating-vue": {
      "types": "./dist/client/b-floating-vue.d.ts",
      "default": "./dist/client/b-floating-vue.js"
    },
    "./iconify": {
      "types": "./dist/client/b-iconify.d.ts",
      "default": "./dist/client/b-iconify.js"
    },
    "./pinia": {
      "types": "./dist/client/b-pinia.d.ts",
      "default": "./dist/client/b-pinia.js"
    },
    "./scroll": {
      "types": "./dist/client/b-scroll.d.ts",
      "default": "./dist/client/b-scroll.js"
    },
    "./vue-router": {
      "types": "./dist/client/b-vue-router.d.ts",
      "default": "./dist/client/b-vue-router.js"
    },
    "./vue-use": {
      "types": "./dist/client/b-vue-use.d.ts",
      "default": "./dist/client/b-vue-use.js"
    },
    "./vue": {
      "types": "./dist/client/b-vue.d.ts",
      "default": "./dist/client/b-vue.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "build": "rimraf dist && rolldown -c rolldown.config.mjs"
  },
  "dependencies": {
    "@iconify/vue": "^4.1.2",
    "@vueuse/core": "catalog:",
    "floating-vue": "5.2.2",
    "pinia": "^2.3.0",
    "scroll-into-view-if-needed": "^3.1.0",
    "vue": "^3.5.38",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "rolldown": "^1.0.3",
    "rolldown-plugin-dts": "^0.26.0",
    "typescript": "catalog:"
  }
}
