{
  "compilerOptions": {
    "target": "ESNext",
    // Volar
    "jsx": "preserve",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    // Alias
    "paths": {
      "floating-vue": ["./node_modules/@histoire/vendors/node_modules/floating-vue"],
      "@iconify/vue": ["./node_modules/@histoire/vendors/node_modules/@iconify/vue"],
      "pinia": ["./node_modules/@histoire/vendors/node_modules/pinia"],
      "scroll-into-view-if-needed": ["./node_modules/@histoire/vendors/node_modules/scroll-into-view-if-needed"],
      "@vueuse/core": ["./node_modules/@histoire/vendors/node_modules/@vueuse/core"],
      "vue": ["./node_modules/@histoire/vendors/node_modules/vue"]
    },
    "resolveJsonModule": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "alwaysStrict": true,
    // Strict
    "noImplicitAny": false,
    "noImplicitThis": true,
    // Output
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "removeComments": false,
    "sourceMap": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "preserveWatchOutput": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "generated/**/*",
    "dist/**/*",
    "src/**/*.spec.ts"
  ]
}
