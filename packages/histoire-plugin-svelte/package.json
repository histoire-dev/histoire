{
  "name": "@histoire/plugin-svelte",
  "type": "module",
  "version": "1.0.0-beta.1",
  "description": "Histoire plugin for Svelte 4/5 and SvelteKit support",
  "author": {
    "name": "Guillaume Chau"
  },
  "license": "MIT",
  "repository": {
    "url": "https://github.com/Akryum/histoire.git",
    "type": "git",
    "directory": "packages/histoire-plugin-svelte"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./client": "./dist/client/index.js",
    "./collect": "./dist/collect/index.js",
    ".": "./dist/index.node.js",
    "./*": "./*"
  },
  "main": "./dist/index.node.js",
  "module": "./dist/index.node.js",
  "types": "./dist/index.node.d.ts",
  "scripts": {
    "build": "rimraf dist && vite build && tsc -d -P tsconfig.build.json && pnpm run build:types",
    "build:types": "tsc --declaration --emitDeclarationOnly",
    "watch": "concurrently \"vite build --watch\" \"tsc -d -P tsconfig.build.json --watch\" \"pnpm run build:types --watch\""
  },
  "peerDependencies": {
    "histoire": "workspace:^",
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "dependencies": {
    "@histoire/controls": "workspace:^",
    "@histoire/shared": "workspace:^",
    "@histoire/vendors": "workspace:^",
    "change-case": "^5.4.4",
    "globby": "^14.0.2",
    "launch-editor": "^2.9.1",
    "pathe": "^1.1.2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^22.10.1",
    "concurrently": "^9.1.0",
    "fs-extra": "^11.2.0",
    "globby": "^14.0.2",
    "histoire": "workspace:*",
    "svelte": "5.55.0",
    "svelte-preprocess": "^6.0.3",
    "typescript": "catalog:",
    "vite": "^8.0.0"
  }
}
